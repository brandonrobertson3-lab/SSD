# ─── PlumbVoice Environment Configuration ────────────────────────────

# Database (PostgreSQL - required for production, optional for dev with in-memory store)
DATABASE_URL=postgresql://user:password@localhost:5432/plumbvoice

# Stripe Payment Integration (optional - enables online card payments)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# Gmail Integration (optional - enables email sending via Gmail API)
# Set up at: https://console.cloud.google.com → APIs & Services → Credentials
GMAIL_CLIENT_ID=your_gmail_client_id
GMAIL_CLIENT_SECRET=your_gmail_client_secret
GMAIL_REFRESH_TOKEN=your_gmail_refresh_token
GMAIL_USER=your_email@gmail.com

# App Configuration
PORT=3000
APP_URL=http://localhost:5000
NODE_ENV=development
